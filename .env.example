# Smart Product Price Comparison Assistant - Environment Variables
# Copy this file to .env and fill in your API keys

# SerpAPI Key (for Amazon product search)
# Get your key at: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Firecrawl API Key (for scraping other e-commerce stores)
# Get your key at: https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Google API Key (for Gemini 2.0 Flash LLM)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Cache TTL in seconds (default: 900 = 15 minutes)
CACHE_TTL=900

# Maximum products to fetch per source
MAX_PRODUCTS_PER_SOURCE=10

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
